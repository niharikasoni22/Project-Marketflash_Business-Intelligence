CREATE TABLE Clients
  (
  client_id varchar(10) PRIMARY KEY NOT NULL
, company_name varchar(15) NOT NULL
, address varchar(100)
, email varchar(20) UNIQUE NOT NULL
, phone varchar(20) NOT NULL
, contact_person varchar(50) NOT NULL
  )
  ;

CREATE TABLE Executives
  (
  executive_id varchar(10) PRIMARY KEY NOT NULL
, name varchar(100) NOT NULL
, phone varchar(20) NOT NULL 
, email varchar(20) UNIQUE NOT NULL 
  )
  ;

  
CREATE TABLE Channel
  (
  channel_id varchar(10) PRIMARY KEY NOT NULL
, name varchar(50) NOT NULL
  )
  ;

CREATE TABLE Campaign_type
  (
  campaign_type_id varchar(10) PRIMARY KEY NOT NULL 
, name varchar(100) NOT NULL
  )
  ;

CREATE TABLE Locations
  (
  location_id varchar(10) PRIMARY KEY NOT NULL
, name varchar(20)
  )
  ;

CREATE TABLE Audiences
  (
  audience_id varchar(10) PRIMARY KEY NOT NULL 
, name varchar(10) NOT NULL 
, age_group varchar(20) NOT NULL 
  )
  ;


CREATE TABLE Campaigns
  (
  campaign_id varchar(10) PRIMARY KEY NOT NULL 
, name varchar(100) NOT NULL
, start_date datetime NOT NULL
, end_date datetime
, views int
, likes int
, clicks int
, conversions int
, expenses decimal(10,2)
, total_sales decimal(10,2)
, client_id varchar(10) NOT NULL 
, executive_id varchar(10) NOT NULL
, channel_id varchar(10) NOT NULL
, campaign_type_id varchar(10) NOT NULL
, audience_id varchar(10) NOT NULL
, location_id varchar(10) NOT NULL
, FOREIGN KEY(client_id) REFERENCES Clients(client_id)
, FOREIGN KEY(executive_id) REFERENCES Executives(executive_id)
, FOREIGN KEY(channel_id) REFERENCES Channel(channel_id) 
, FOREIGN KEY(campaign_type_id) REFERENCES Campaign_type(campaign_type_id)  
, FOREIGN KEY(audience_id) REFERENCES Audiences(audience_id)
, FOREIGN KEY(location_id) REFERENCES Locations(location_id)
  )
  ;
